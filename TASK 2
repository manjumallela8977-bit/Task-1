        "def fib(n):\n",
        "    if n<=0:\n",
        "        return \"invalid\"\n",
        "    elif n==1:\n",
        "        return 0\n",
        "    elif n==2:\n",
        "        return 1\n",
        "    else:\n",
        "        return fib(n-1)+fib(n-2)\n",
        "\n",
        "fib(30)"
      ],
